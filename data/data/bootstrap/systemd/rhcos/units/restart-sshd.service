[Unit]
Description=Restart sshd after initial boot (OCPBUGS-77255 workaround)
Documentation=https://issues.redhat.com/browse/OCPBUGS-77255
After=node-image-overlay.service
ConditionPathExists=!/run/restart-sshd-workaround

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/touch /run/restart-sshd-workaround
ExecStart=/bin/systemctl try-restart sshd.service

[Install]
WantedBy=multi-user.target
