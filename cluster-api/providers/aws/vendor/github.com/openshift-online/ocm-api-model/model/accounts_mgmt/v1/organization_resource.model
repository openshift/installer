// Manages a specific organization.
resource Organization {
	// Retrieves the details of the organization.
	method Get {
		out Body Organization
	}

	// Updates the organization.
	method Update {
		in out Body Organization
	}

	// Reference to the service that manages the resource quotas for this
	// organization.
	locator ResourceQuota {
		target ResourceQuotas
	}

	// Reference to the list of labels of a specific organization.
	locator Labels {
		target GenericLabels
	}

	// Reference to the service that manages the resource quotas for this
	// organization.
	locator SummaryDashboard {
		target SummaryDashboard
	}

	// Reference to the service that returns a summary of quota cost for this organization
	locator QuotaCost {
		target QuotaCost
	}

  // Reference to the service that manages the account groups for this organization.
  locator AccountGroups {
    target AccountGroups
  }

  // Reference to the service that manages the account group assignments for this organization.
  locator AccountGroupAssignments {
    target AccountGroupAssignments 
  }
}
